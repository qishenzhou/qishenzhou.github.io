@article{yang2026ORThought,
  title = {ORThought：基于结构化大语言模型推理的物流优化建模基准测试与自动化方法},
  abstract = {优化建模是物流与交通领域科学决策的核心引擎，但其应用因较高的专业门槛和繁琐的人工流程而受到制约。利用大语言模型（LLMs）实现这一过程的自动化是一种可行方案，但现有方法面临三方面瓶颈：（i）缺乏高质量的复杂基准；（ii）自主多智能体框架存在方法论上的低效问题，往往表现出不稳定性和冗余计算；（iii）评估维度不够深入。本文从以下三个方面应对上述挑战：首先，提出 LogiOR，一个标注严谨、场景多样的物流基准数据集，并以相同标注标准丰富现有数据集，以支持社区应用；其次，提出 ORThought，一种结构化双智能体框架，通过引入链式推理的专家级建模原则，消除了无约束自主智能体的冗余问题；第三，大量实证评估表明，ORThought 在各基准方法上持续领先 9–17 个百分点，在处理复杂约束方面表现出显著优势，同时保持较高的 token 效率。在此基础上，本文进一步开展多维误差分析，识别关键失败模式与成功要素，为后续研究提供可操作的参考见解。数据集和代码分别在 [Hugging Face](https://huggingface.co/datasets/LabMem012/LogiOR) 和 [GitHub](https://github.com/ZJU-TSELab/ORThought) 上开放获取。}
}

@article{zhou2025NetworkWidea,
  title = {基于稀疏传感器数据的路网交通状态估计：一种基于 Dirichlet 能量的图自编码器方法},
  abstract = {路网交通状态估计（traffic state estimation，TSE）旨在利用稀疏布设的传感器重建路网交通状态的完整时空画像，在智能交通系统中具有重要应用价值。随着数据驱动方法的快速发展，交通动力学建模取得了显著进展，但对于 TSE 而言，数据驱动方法仍面临根本性挑战，因为在无传感器路段无法直接学习局部历史模式。图表示学习为无传感器位置的状态估计提供了新的思路，但现有方法通常通过零填充处理未观测节点，这会在敏感的图消息传播过程中引入偏差。基于 Dirichlet 能量的特征传播（Dirichlet Energy-based Feature Propagation，DEFP）通过摆脱零填充依赖，在未观测节点分类任务中取得了领先性能，但其直接用于 TSE 仍面临三方面困难：难以刻画有向交通网络，对交通空间相关性的假设较强，以及忽视拥堵与自由流等不同交通模式的差异化传播规律。针对上述问题，本文提出一种归纳式图表示模型 DGAE，通过理论推导的有向图 DEFP 方法（DEFP4D）、DEFP4D 引导的潜在空间编码增强空间表示学习，以及分别刻画拥堵与自由流的物理机理引导传播机制，实现对上述挑战的有效应对。三个交通数据集上的实验结果表明，DGAE 优于现有先进方法，并具有良好的跨城市迁移能力；此外，DEFP4D 还可作为一种独立的轻量化方案，在极端稀疏传感器条件下仍表现出优异性能。}
}

@article{zhou2025mogernn,
  title = {MoGERNN：面向未观测位置的归纳式交通状态预测方法},
  abstract = {在部分观测的路网中，如何准确预测未布设传感器位置的交通状态，是交通管理与控制中的关键问题。交通预测对于先进交通管理系统至关重要，深度学习方法已经展现出优越性能，但现有大多数方法通常假设所有关注位置均已布设传感器，这在实际应用中受成本约束难以实现；同时，这类方法对传感网络结构变化较为敏感，即便传感器配置发生微小调整，也往往需要代价高昂的重新训练。针对上述问题，本文提出 MoGERNN，一种归纳式时空图模型，由两个核心组件构成：（i）基于稀疏门控机制的图专家混合（Mixture of Graph Experts，MoGE）模块，可将节点动态路由至专用图聚合器，从而高效刻画异质空间依赖；（ii）图编码器-解码器结构，利用所学习的嵌入同时建模空间与时间依赖，实现交通状态的综合预测。两个真实数据集上的实验结果表明，MoGERNN 在已观测位置和未观测位置均持续优于基线方法，能够在无传感器区域准确刻画拥堵演化，并为交通管理提供有效信息；同时，MoGERNN 对传感网络变化具有较强适应性，即使与重新训练后的模型相比仍保持较强竞争力。不同传感器数量下的测试进一步验证了其稳定优势，消融实验则验证了各关键模块的有效性。}
}

@article{zhang2025CASAformer,
  title = {CASAformer：面向交通速度预测的拥堵感知稀疏注意力 Transformer},
  abstract = {准确、高效的交通速度预测对于提升道路安全与运行效率至关重要。随着深度学习方法和大规模交通数据的快速发展，数据驱动方法已被广泛采用，模型结构也日趋复杂、网络层数不断加深，但多数模型仅优化整体平均性能，并未区分不同交通状态。事实上，拥堵状态下的速度预测通常比自由流状态下更为重要，因为交通控制与优化等下游任务往往更关注拥堵过程。然而，现有多数先进（state-of-the-art，SOTA）模型在训练与评估阶段并未区分交通状态。针对这一问题，本文首先系统分析了 SOTA 模型在不同速度区间的预测表现，揭示了低速条件下预测精度偏低的现象；进一步提出拥堵感知稀疏注意力 Transformer（Congestion-Aware Sparse Attention Transformer，CASAformer），以提升低速交通条件下的预测性能。具体而言，CASA 层强化拥堵样本的权重并弱化自由流样本的影响，同时引入新的拥堵自适应损失函数进行训练，使模型更多从拥堵数据中学习。真实数据集上的大量实验表明，CASAformer 在所有预测时域内对 40 mph 以下速度的预测均优于现有 SOTA 模型。}
}

@article{zhou2024CooperativeTrafficSignal,
  title = {基于激励通信的分布式多智能体深度强化学习协同交通信号控制},
  abstract = {深度强化学习在动态交通信号控制中具有较强应用潜力，能够随实时交通条件自适应调整控制策略；但对于多交叉口协同控制而言，仍面临诸多挑战，主要体现在跨交叉口信息交换效率需求较高，以及交通流时空动力学特征复杂。传统方法往往仅侧重空间或时间单一维度，因而难以获得最优控制效果。针对上述问题，本文提出一种面向多交叉口协同控制的多智能体激励通信深度强化学习方法（Multi-Agent Incentive Communication Deep Reinforcement Learning，MICDRL）。该方法通过激励通信机制，使智能体能够生成影响其他智能体策略的定制化消息，从而增强协同并实现全局最优决策；同时，仅依赖局部信息生成消息，在保证协同效果的前提下有效降低通信开销。此外，MICDRL 还集成队友模块，利用时序数据预测其他智能体的动作，以刻画群体动力学与空间环境特征。实验结果表明，MICDRL 在排队长度、通行量等指标上均优于多种先进方法；同时，本文还设计了配套的三层物联网架构，以支撑数据采集与传输。}
}


@article{zhou2023Safetyenhanced,
  title = {网联与自动驾驶车辆的安全增强型生态驾驶策略：分层分布式框架},
  abstract = {本文提出一种面向网联与自动驾驶车辆（connected and autonomous vehicles，CAVs）的安全增强型生态驾驶策略，并采用分层分布式框架加以实现。该框架将驾驶风险场、冲击波理论以及运动规划与控制方法有机结合，用于优化混合交通流条件下信号化干道上 CAV 的行驶轨迹，在保证交通效率的同时降低 CAV 的驾驶风险与燃油消耗。优化过程主要包括两部分：基于最优控制的长期轨迹规划，以及基于模型预测控制的短期轨迹控制，从而使策略更适应多样化交通场景。结果表明，所提框架可将车辆面临的安全风险和燃油消耗分别降低 18%–24% 和 20%–27%。进一步分析发现，仅考虑前车影响时，传统生态驾驶策略可能对安全性产生不利影响；而在纳入后车对生态驾驶 CAV 的影响后，这些不利影响可以被消除。此外，对 CAV 市场渗透率（MPR）和交通需求的敏感性分析表明，该框架具有较好的鲁棒性，可在欠饱和与过饱和等不同交通条件以及不同 MPR 下有效运行。}
}

@article{hu2022HighTimeResolutionQueue,
  title = {基于扩展卡尔曼滤波的信号交叉口排队轮廓高时间分辨率估计},
  abstract = {城市交叉口排队长度的动态时空特性对于信号配时性能评价与信号优化等交通运行任务至关重要。本文基于网联车辆（connected vehicles，CVs）数据，采用扩展卡尔曼滤波（Extended Kalman Filtering，EKF）实现城市信号交叉口排队轮廓的高时间分辨率估计。主要贡献包括：（i）结合冲击波理论与 CV 历史数据，采用机器学习方法构建动态冲击波传播模型；（ii）提出一种启发式方法用于估计冲击波速度，并将其用于 EKF；（iii）设计城市排队估计器，将动态冲击波传播模型与基于 EKF 的实时冲击波信息相结合，实现逐秒排队轮廓估计。该估计器无需车辆到达模式和 CV 市场渗透率（MPR）的先验信息。通过仿真和真实 CV 数据对估计器性能与鲁棒性进行了评估，结果表明：该方法在不同 CV 渗透率下均能获得令人满意的估计结果，在 MPR 为 5% 时估计误差约为 2.5 辆车，在 MPR 为 40% 时约为 0.5 辆车。}
}

