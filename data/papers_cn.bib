@article{zhou2025NetworkWidea,
  title = {基于稀疏传感器数据的路网交通状态估计：一种基于 Dirichlet 能量的图自编码器方法},
  abstract = {路网交通状态估计（TSE）旨在利用稀疏布设的传感器推断路网交通状态的完整画像，在智能交通系统中具有重要地位。随着数据驱动方法的发展，交通动力学建模取得了显著进展，但 TSE 对数据驱动方法仍构成根本性挑战，因为无传感器路段无法在局部学习历史模式。图表示学习虽在无传感器位置的状态估计方面展现出潜力，但现有方法通常以零填充方式处理未观测位置，会为敏感的图消息传播引入偏差。基于 Dirichlet 能量的特征传播（DEFP）方法通过消除零填充需求，在未观测节点分类上取得了领先性能，但其应用于 TSE 仍面临三方面挑战：无法处理有向交通网络、对交通空间相关性假设过强、以及忽视不同交通模式（如拥堵与自由流）的差异化传播规律。本文提出 DGAE，一种归纳式图表示模型，通过理论推导的有向图 DEFP（DEFP4D）、基于 DEFP4D 引导的潜在空间编码增强空间表示学习，以及分别刻画拥堵与自由流的物理引导传播机制，应对上述挑战。在三个交通数据集上的实验表明，DGAE 优于现有先进方法，并具有良好的跨城市迁移能力；DEFP4D 还可作为独立轻量方案，在极稀疏传感器条件下仍表现优异。}
}

@article{zhou2025mogernn,
  title = {MoGERNN：面向未观测位置的归纳式交通状态预测方法},
  abstract = {在部分观测的路网中，如何预测未布设传感器位置的交通状态是交通管理与控制中的关键问题。交通预测对先进交通管理系统至关重要，深度学习方法已展现出优异性能，但多数现有方法假定所有关注位置均布设传感器，在实际中受成本约束难以满足；且这些方法对传感网络结构变化较为敏感，传感器配置的微小变动往往需要代价高昂的重新训练。针对上述问题，本文提出 MoGERNN，一种归纳式时空图模型，包含两个核心组件：（i）基于稀疏门控的图专家混合（MoGE）模块，将节点动态路由至专用图聚合器，高效刻画异质空间依赖；（ii）图编码器-解码器结构，利用所得嵌入同时建模空间与时间依赖，实现交通状态的综合预测。在两个真实数据集上的实验表明，MoGERNN 在已观测与未观测位置均持续优于基线方法，能在无传感器区域准确预测拥堵演化，并为交通管理提供有效信息；同时，MoGERNN 能适应传感网络变化，在与重训练模型对比中仍保持竞争力。不同传感器数量下的测试验证了其稳定优势，消融实验验证了各关键模块的有效性。}
}

@article{zhou2023Safetyenhanced,
  title = {网联与自动驾驶车辆的安全增强型生态驾驶策略：分层分布式框架},
  abstract = {本文提出一种面向网联与自动驾驶车辆（CAV）的安全增强型生态驾驶策略，采用分层分布式框架实现。该框架将驾驶风险场、冲击波理论与运动规划控制方法相结合，在混合交通流下的信号控制干道上优化 CAV 轨迹，在保证交通效率的前提下同时降低 CAV 的驾驶风险与燃油消耗。优化过程主要包括两部分：基于最优控制的长期轨迹规划与基于模型预测控制的短期轨迹控制，使策略更能适应多样化的交通状况。结果表明，所提框架可有效降低车辆面临的安全风险与燃油消耗，降幅分别为 18\%--24\% 与 20\%--27\%。进一步发现，仅考虑前车对生态驾驶 CAV 影响时，传统生态驾驶策略可能带来不利的安全影响；而在考虑后车对生态驾驶 CAV 的影响后，这些不利影响可被消除。此外，对 CAV 市场渗透率（MPR）与交通需求的敏感性分析表明，该框架具有较好的鲁棒性，可在不同交通条件（欠饱和与过饱和）及不同 MPR 下有效运行。}
}

@article{hu2022HighTimeResolutionQueue,
  title = {基于扩展卡尔曼滤波的信号交叉口排队长度高时间分辨率估计},
  abstract = {城市交叉口排队长度的动态时空特性对信号绩效评估与信号优化等交通运行任务至关重要。本文基于网联车辆（CV）数据，采用扩展卡尔曼滤波（EKF）实现城市信号交叉口排队长度的高时间分辨率估计。主要贡献包括：（i）结合冲击波理论与 CV 历史数据，采用机器学习方法构建动态冲击波传播模型；（ii）提出一种启发式方法用于估计冲击波速度并用于 EKF；（iii）设计城市排队估计器，将动态冲击波传播模型与基于 EKF 的实时冲击波信息相结合，实现逐秒排队长度估计。该估计器无需车辆到达模式与 CV 市场渗透率（MPR）的先验信息。通过仿真与真实 CV 数据对估计器性能与鲁棒性进行了评估，结果表明：该方法可在不同 CV 渗透率下获得满意的估计结果，在 MPR 为 5\% 时估计误差约 2.5 车，在 MPR 为 40\% 时约 0.5 车。}
}

@article{zhang2025CASAformer,
  title = {CASAformer：面向交通速度预测的拥堵感知稀疏注意力 Transformer},
  abstract = {准确、高效的交通速度预测对提升道路安全与效率至关重要。随着深度学习与大规模交通数据的涌现，数据驱动方法被广泛采用，模型结构日趋复杂、网络层数不断加深，但多数模型旨在优化整体平均性能，未区分不同交通状态。事实上，拥堵状态下的速度预测通常比自由流下更为重要，因为交通控制与优化等下游任务更关注拥堵。然而，多数先进（SOTA）模型在训练与评估时并未区分交通状态。为此，本文首先系统考察了 SOTA 模型在不同速度区间的表现，揭示了低速预测精度偏低的现象；进而提出并设计了一种拥堵感知稀疏注意力 Transformer（CASAformer），以提升低速交通条件下的预测性能。具体而言，CASA 层强化拥堵数据的权重并弱化自由流数据的影响，并采用新的拥堵自适应损失函数进行训练，使模型更多从拥堵数据中学习。在真实数据集上的大量实验表明，CASAformer 在所有预测时域内对 40 mph 以下速度的预测均优于 SOTA 模型。}
}

@article{zhou2024CooperativeTrafficSignal,
  title = {基于激励通信的分布式多智能体深度强化学习协同交通信号控制},
  abstract = {深度强化学习通过适应实时交通条件，在动态交通信号控制中展现出潜力；但多交叉口控制仍面临挑战，主要源于跨交叉口信息交换效率的需求以及交通流时空动力学的重要性。传统方法往往仅侧重空间或时间单一方面，导致控制策略次优。本文提出一种面向多交叉口协同控制的多智能体激励通信深度强化学习（MICDRL）方法。MICDRL 采用激励通信机制，使智能体生成可影响其他智能体策略的定制化消息，从而增强协调并实现全局最优决策；其特点在于仅依赖局部信息生成消息，在保证协同的同时有效降低通信开销。此外，MICDRL 集成队友模块，利用时序数据预测其他智能体的动作，以理解集体动力学与空间环境特征。实验结果表明，MICDRL 在排队长度、通行量等指标上优于多种先进方法；本文还给出了配套的三层物联网架构，以支撑数据采集与传输。}
}
